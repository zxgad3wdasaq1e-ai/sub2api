# Copy this file to .env and fill in values for your deployment.
# The app uses DATABASE_* variables (not DB_*) because they match the existing
# Viper config keys: database.host -> DATABASE_HOST.

# Host port mapping
BIND_HOST=0.0.0.0
SERVER_PORT=8080

# Application runtime
AUTO_SETUP=true
SERVER_MODE=release
RUN_MODE=standard
TZ=Asia/Shanghai

# External PostgreSQL
DATABASE_HOST=host.docker.internal
DATABASE_PORT=5432
DATABASE_USER=sub2api
DATABASE_PASSWORD=change_this_database_password
DATABASE_DBNAME=sub2api
DATABASE_SSLMODE=disable
DATABASE_MAX_OPEN_CONNS=50
DATABASE_MAX_IDLE_CONNS=10
DATABASE_CONN_MAX_LIFETIME_MINUTES=30
DATABASE_CONN_MAX_IDLE_TIME_MINUTES=5

# External Redis
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=1024
REDIS_MIN_IDLE_CONNS=10
REDIS_ENABLE_TLS=false

# Initial admin account. Leave ADMIN_PASSWORD empty to auto-generate it on first run.
ADMIN_EMAIL=admin@sub2api.local
ADMIN_PASSWORD=

# Security secrets. Generate production values with:
#   openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRE_HOUR=24
TOTP_ENCRYPTION_KEY=

# Setup / migrations
SETUP_MIGRATION_TIMEOUT_SECONDS=0

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT_TO_STDOUT=true
LOG_OUTPUT_TO_FILE=true

# Optional update / provider configuration
UPDATE_GITHUB_TOKEN=
GEMINI_OAUTH_CLIENT_ID=
GEMINI_OAUTH_CLIENT_SECRET=
GEMINI_OAUTH_SCOPES=
GEMINI_QUOTA_POLICY=
